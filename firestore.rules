rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isNotBanned() {
      return isSignedIn() && 
             (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
              getUserData(request.auth.uid).get('isBanned', false) == false);
    }

    function isTeacher() {
      return isSignedIn() && isNotBanned() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData(request.auth.uid).role == 'teacher';
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'bamuyahacksie@gmail.com';
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['student', 'teacher'] &&
             isValidId(data.uid) &&
             data.createdAt is string &&
             (data.get('photoURL', '') == '' || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             data.get('isBanned', false) is bool;
    }

    match /users/{uid} {
      allow get: if isSignedIn();
      
      allow list: if isSignedIn() && (
        isSuperAdmin() ||
        isTeacher() ||
        isSignedIn() // Simplified but can be refined later if needed
      );
      
      allow create: if isOwner(uid) && isValidUser(incoming()) && 
                      incoming().uid == request.auth.uid &&
                      incoming().role in ['student', 'teacher'] &&
                      incoming().get('isBanned', false) == false;

      allow update: if isSuperAdmin() || (
        isOwner(uid) && isValidUser(incoming()) && isNotBanned() &&
        incoming().role == existing().role &&
        incoming().uid == existing().uid &&
        incoming().get('isBanned', false) == existing().get('isBanned', false)
      ) || (
        isTeacher() && existing().role == 'student' && 
        incoming().diff(existing()).affectedKeys().hasOnly(['isBanned']) &&
        isValidUser(incoming())
      );

      allow delete: if isSuperAdmin() || isOwner(uid);
    }

    function isValidQuiz(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.teacherId is string && isValidId(data.teacherId) &&
             data.questions is list && data.questions.size() <= 100 &&
             data.createdAt is string &&
             (data.get('deadline', '') == '' || data.deadline is string) &&
             data.get('isPublic', false) is bool &&
             data.get('isHidden', false) is bool;
    }

    match /quizzes/{quizId} {
      allow get: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (
        existing().teacherId == request.auth.uid ||
        existing().get('isPublic', false) == true ||
        request.auth.uid in existing().get('allowedStudentIds', [])
      ));
      
      allow list: if isSignedIn() && isNotBanned();

      allow create: if isTeacher() && isValidQuiz(incoming()) && 
                      incoming().teacherId == request.auth.uid;
      
      allow update: if isSuperAdmin() || (
        isTeacher() && existing().teacherId == request.auth.uid && 
        isValidQuiz(incoming()) && incoming().teacherId == existing().teacherId
      );
      
      allow delete: if isSuperAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }

    function isValidSubmission(data) {
      return data.studentId is string && isValidId(data.studentId) &&
             data.quizId is string && isValidId(data.quizId) &&
             data.score is number && data.totalPoints is number &&
             data.submittedAt is string &&
             data.get('studentRole', '') is string &&
             data.get('graded', false) is bool &&
             data.get('teacherId', '') is string &&
             data.get('quizTitle', '') is string;
    }

    match /submissions/{submissionId} {
      allow get: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (
        existing().studentId == request.auth.uid || 
        existing().teacherId == request.auth.uid
      ));

      allow list: if isSignedIn() && isNotBanned() && (
        isSuperAdmin() ||
        resource.data.studentId == request.auth.uid ||
        resource.data.teacherId == request.auth.uid
      );
      
      allow create: if isSignedIn() && isNotBanned() && 
                      isValidSubmission(incoming()) &&
                      incoming().studentId == request.auth.uid &&
                      incoming().teacherId == get(/databases/$(database)/documents/quizzes/$(incoming().quizId)).data.teacherId;
      
      allow update, delete: if isSuperAdmin() || (isSignedIn() && (
        existing().studentId == request.auth.uid || 
        existing().teacherId == request.auth.uid
      ));
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isSuperAdmin());
      allow create: if isTeacher() || isSuperAdmin();
      allow update: if isSignedIn() && isNotBanned() && existing().userId == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && isNotBanned() && existing().userId == request.auth.uid;
    }
  }
}
