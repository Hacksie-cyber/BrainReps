rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isNotBanned() {
      return !isSignedIn() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             getUserData().get('isBanned', false) == false;
    }

    function isTeacher() {
      return isSignedIn() && isNotBanned() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && isNotBanned() && getUserData().role == 'student';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'bamuyahacksie@gmail.com';
    }

    match /users/{uid} {
      // Allow users to read their own profile no matter what to detect ban status.
      // For shared student/teacher lookups, we use the isNotBanned check.
      allow read: if isSuperAdmin() || (isSignedIn() && (request.auth.uid == uid || isTeacher() || isNotBanned()));
      
      allow write: if isSuperAdmin() || (isOwner(uid) && isNotBanned() && (
        // Allow creating profile if it doesn't exist
        !exists(/databases/$(database)/documents/users/$(uid)) || 
        // Allow updates only if role and isBanned remain the same for owner
        (exists(/databases/$(database)/documents/users/$(uid)) && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false))
      )) || (
        // Allow teachers to ban/unban students
        isTeacher() && 
        resource.data.role == 'student' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBanned'])
      );

      allow delete: if isSuperAdmin() || isOwner(uid);
    }

    match /quizzes/{quizId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (
        resource.data.teacherId == request.auth.uid ||
        resource.data.get('isPublic', false) == true ||
        request.auth.uid in resource.data.get('allowedStudentIds', [])
      ));
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
    }

    function isValidSubmission(data) {
      return data.studentId is string &&
             data.studentRole is string &&
             data.quizId is string &&
             data.score is number &&
             data.totalPoints is number &&
             data.submittedAt is string &&
             data.graded is bool &&
             data.teacherId is string;
    }

    match /submissions/{submissionId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        (resource.data.get('quizId', '') != '' && 
         get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.teacherId == request.auth.uid)
      ));
      
      allow create: if isSignedIn() && isNotBanned() && 
        isValidSubmission(request.resource.data) &&
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.teacherId == get(/databases/$(database)/documents/quizzes/$(request.resource.data.quizId)).data.teacherId;
      
      allow update: if false;
      allow delete: if isSuperAdmin() || (isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid ||
        (resource.data.get('quizId', '') != '' && 
         get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.teacherId == request.auth.uid)
      ));
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if isTeacher();
      allow update: if isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && 
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid;
    }
  }
}
