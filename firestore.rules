rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'bamuyahacksie@gmail.com' &&
             request.auth.token.email_verified == true;
    }

    function isNotBanned() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false
      );
    }

    function isTeacher() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             data.role in ['student', 'teacher'] &&
             isValidId(data.uid) &&
             data.createdAt is string &&
             (data.get('photoURL', '') == '' || (data.photoURL is string && data.photoURL.size() <= 1000)) &&
             (data.get('bio', '') == '' || (data.bio is string && data.bio.size() <= 500)) &&
             data.get('isBanned', false) is bool;
    }

    match /users/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (isSuperAdmin() || isTeacher() || resource.data.role == 'student');
      
      allow create: if isOwner(uid) && isValidUser(incoming()) && 
                      incoming().uid == request.auth.uid &&
                      incoming().get('isBanned', false) == false;

      allow update: if isSuperAdmin() || (
        isOwner(uid) && isValidUser(incoming()) && isNotBanned() &&
        incoming().role == existing().role &&
        incoming().get('isBanned', false) == existing().get('isBanned', false) &&
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt
      ) || (
        isTeacher() && existing().role == 'student' && 
        incoming().diff(existing()).affectedKeys().hasOnly(['isBanned']) &&
        isValidUser(incoming())
      );

      allow delete: if isSuperAdmin();
    }

    function isValidQuiz(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.teacherId is string && isValidId(data.teacherId) &&
             data.questions is list && data.questions.size() <= 100 &&
             data.createdAt is string &&
             (data.get('deadline', '') == '' || data.deadline is string) &&
             data.get('isPublic', false) is bool &&
             data.get('isHidden', false) is bool;
    }

    match /quizzes/{quizId} {
      allow get: if isSignedIn() && isNotBanned();
      allow list: if isSignedIn();

      allow create: if isTeacher() && isValidQuiz(incoming()) && 
                      incoming().teacherId == request.auth.uid;
      
      allow update: if isSuperAdmin() || (
        isTeacher() && existing().teacherId == request.auth.uid && 
        isValidQuiz(incoming()) && incoming().teacherId == existing().teacherId
      );
      
      allow delete: if isSuperAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }

    function isValidSubmission(data) {
      return data.studentId is string &&
             data.quizId is string &&
             data.score is number && 
             data.totalPoints is number &&
             data.submittedAt is string &&
             data.get('graded', false) is bool &&
             data.get('status', 'in-progress') in ['in-progress', 'completed'] &&
             (data.get('rank', 0) is number || data.get('rank', 0) is int) &&
             (data.get('totalParticipants', 0) is number || data.get('totalParticipants', 0) is int) &&
             (data.get('serverTimestamp', null) == null || data.serverTimestamp is timestamp);
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && isNotBanned() && (
        resource.data.get('studentId', '') == request.auth.uid || 
        resource.data.get('teacherId', '') == request.auth.uid || 
        isSuperAdmin()
      );
      
      allow list: if isSignedIn() && (
        isSuperAdmin() ||
        resource.data.get('teacherId', '') == request.auth.uid || 
        resource.data.get('studentId', '') == request.auth.uid ||
        resource.data.get('status', '') == 'completed'
      ); 
      
      allow create: if isSignedIn() && isNotBanned() && 
                      incoming().studentId == request.auth.uid &&
                      isValidSubmission(incoming());
      
      allow update: if isSuperAdmin() || (
        isSignedIn() && isNotBanned() && (
          // Student can update their own submission
          (existing().get('studentId', '') == request.auth.uid && (
            // standard progress updates
            (existing().get('graded', false) == false && isValidSubmission(incoming())) ||
            // metrics sync allowed after completion
            (existing().get('graded', false) == true && incoming().diff(existing()).affectedKeys().hasOnly(['rank', 'totalParticipants']))
          )) ||
          // Teacher can update
          (existing().get('teacherId', '') == request.auth.uid)
        )
      );

      allow delete: if isSuperAdmin() || (isTeacher() && existing().get('teacherId', '') == request.auth.uid);
    }

    function isValidHandout(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.teacherId is string && isValidId(data.teacherId) &&
             data.createdAt is string &&
             data.get('isPublic', true) is bool;
    }

    match /handouts/{handoutId} {
      allow read: if isSignedIn() && isNotBanned();
      allow create: if isTeacher() && isValidHandout(incoming()) && 
                      incoming().teacherId == request.auth.uid;
      allow update: if isSuperAdmin() || (
        isTeacher() && existing().teacherId == request.auth.uid && 
        isValidHandout(incoming()) && incoming().teacherId == existing().teacherId
      );
      allow delete: if isSuperAdmin() || (isTeacher() && existing().teacherId == request.auth.uid);
    }

    match /usage/{uId} {
      allow get: if isSignedIn() && (uId.split('_')[0] == request.auth.uid || isSuperAdmin());
      allow create: if isSignedIn() && isNotBanned() && uId.split('_')[0] == request.auth.uid && 
                      incoming().userId == request.auth.uid && 
                      incoming().count == 1;
      allow update: if isSignedIn() && isNotBanned() && uId.split('_')[0] == request.auth.uid && 
                      incoming().count == existing().count + 1 &&
                      incoming().count <= 20;
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isSuperAdmin());
      allow list: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isSuperAdmin());
      
      allow create: if isTeacher() || isSuperAdmin();
      allow update: if isSignedIn() && isNotBanned() && existing().get('userId', '') == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && isNotBanned() && existing().get('userId', '') == request.auth.uid;
    }
  }
}
