rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isNotBanned() {
      return !isSignedIn() || !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || !getUserData().get('isBanned', false);
    }

    function isTeacher() {
      return isSignedIn() && isNotBanned() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && isNotBanned() && getUserData().role == 'student';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{uid} {
      // Allow users to read their own profile no matter what to detect ban status.
      // For shared student/teacher lookups, we use the isNotBanned check.
      allow read: if isSignedIn() && (request.auth.uid == uid || isTeacher() || isNotBanned());
      
      allow write: if (isOwner(uid) && isNotBanned() && (
        // Allow creating profile if it doesn't exist
        (!exists(/databases/$(database)/documents/users/$(uid)) && (
          request.resource.data.role != 'teacher' || 
          request.auth.token.email == 'bamuyahacksie@gmail.com'
        )) || 
        // Allow updates only if role and isBanned remain the same for owner
        (exists(/databases/$(database)/documents/users/$(uid)) && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.get('isBanned', false) == resource.data.get('isBanned', false))
      )) || (
        // Allow teachers to ban/unban students
        isTeacher() && 
        resource.data.role == 'student' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isBanned'])
      );
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn() && isNotBanned() && (
        resource.data.teacherId == request.auth.uid ||
        !resource.data.keys().contains('allowedStudentIds') ||
        resource.data.allowedStudentIds.size() == 0 ||
        request.auth.uid in resource.data.allowedStudentIds
      );
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow update, delete: if isTeacher() && resource.data.teacherId == request.auth.uid;
    }

    function isValidSubmission(data) {
      return data.studentId is string &&
             data.quizId is string &&
             data.score is number &&
             data.totalPoints is number &&
             data.submittedAt is string &&
             data.graded is bool &&
             data.teacherId is string;
    }

    match /submissions/{submissionId} {
      allow read: if isSignedIn() && isNotBanned() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid
      );
      
      allow create: if isSignedIn() && isNotBanned() && 
        isValidSubmission(request.resource.data) &&
        request.resource.data.studentId == request.auth.uid &&
        request.resource.data.teacherId == get(/databases/$(database)/documents/quizzes/$(request.resource.data.quizId)).data.teacherId;
      
      allow update: if false;
      allow delete: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || 
        resource.data.teacherId == request.auth.uid
      );
    }
  }
}
