{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Core identity document for all participants and facilitators.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isBanned": { "type": "boolean" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Quiz": {
      "title": "Knowledge Module",
      "description": "An instructional assessment created by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "questions": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" },
        "allowedStudentIds": { "type": "array", "items": { "type": "string" } },
        "isHidden": { "type": "boolean" },
        "accessCode": { "type": "string" }
      },
      "required": ["title", "teacherId", "questions", "createdAt"]
    },
    "Submission": {
      "title": "Assessment Result",
      "description": "A record of a student's attempt at a quiz.",
      "type": "object",
      "properties": {
        "quizId": { "type": "string" },
        "quizTitle": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "studentRole": { "type": "string" },
        "score": { "type": "number" },
        "totalPoints": { "type": "number" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "graded": { "type": "boolean" },
        "answers": { "type": "array" },
        "teacherId": { "type": "string" },
        "isPublicQuiz": { "type": "boolean" },
        "allowedStudentIds": { "type": "array" }
      },
      "required": ["quizId", "studentId", "score", "totalPoints", "submittedAt"]
    },
    "Notification": {
      "title": "System Notification",
      "description": "Alerts sent to users regarding assessments or institutional updates.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user records."
    },
    "quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of instructional assessments."
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Student assessment attempts."
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}
